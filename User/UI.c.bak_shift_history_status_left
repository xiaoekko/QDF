            PCF8563_SetDateTime(&datetime);
        }
    }
}

void CheckSystemFirstRun(void)
{
    if(AT24CXX_ReadUchar(ADR_SYSTEM_FIRST_RUN) != 0x55) {
        AT24CXX_WriteUchar(ADR_SYSTEM_FIRST_RUN, 0x55);
        HAL_Delay(10);

        ModelID = HandModel;
        SetupModel(ModelID);
        AT24CXX_WriteUchar(ADR_MODELID, ModelID);
        AT24CXX_WriteUchar(ADR_DEVICEID, 1);
        AT24CXX_WriteFloat(ADR_MAXPRESSURE, 10.0f);
        AT24CXX_WriteFloat(ADR_MINPRESSURE, 2.0f);
        AT24CXX_WriteFloat(ADR_ALARM_TEMP, 100.0f);
        AT24CXX_WriteUint(ADDR_DEEP_SLEEP_ADDR, 0);
        MyI2C_WriteUlong(ADDR_SPI_FLASH_ADDR, 1);
        SyncTimeToRTC();
    }

    if(AT24CXX_ReadUchar(ADR_HISTORY_FORMAT_VERSION) != 0xA5) {
        W25QXX_Erase_Chip();
        MyI2C_WriteUlong(ADDR_SPI_FLASH_ADDR, 1);
        AT24CXX_WriteUchar(ADR_HISTORY_FORMAT_VERSION, 0xA5);
    }
}

uint32_t FlashRead_Uint32(uint32_t adr)
{
    return MyI2C_ReadUlong(ADDR_SPI_FLASH_ADDR + adr);
}

void Flash_History_Read(uint32_t number)
{
    uint8_t i;
    uint8_t s[4] = {0};
    uint8_t s1[4] = {0};

    for(i = 0; i < HISTORY_RECORD_SIZE; i++) {
        HistoryBuffRead[i] = 0;
    }

    W25QXX_Read(HistoryBuffRead, number * HISTORY_RECORD_SIZE, HISTORY_RECORD_SIZE);

    s[0] = HistoryBuffRead[10] & 0xFF;
    s[1] = HistoryBuffRead[11] & 0xFF;
    s[2] = HistoryBuffRead[12] & 0xFF;
    s[3] = HistoryBuffRead[13] & 0xFF;

    s1[0] = HistoryBuffRead[14] & 0xFF;
    s1[1] = HistoryBuffRead[15] & 0xFF;
    s1[2] = HistoryBuffRead[16] & 0xFF;
    s1[3] = HistoryBuffRead[17] & 0xFF;

    HistoryData.Year = HistoryBuffRead[0] & 0x3F;
    HistoryData.Month = HistoryBuffRead[1] & 0x0F;
    HistoryData.Day = HistoryBuffRead[2] & 0x1F;
    HistoryData.Hour = HistoryBuffRead[3] & 0x3F;
    HistoryData.Min = HistoryBuffRead[4] & 0x3F;
    HistoryData.Second = HistoryBuffRead[5] & 0x3F;
    HistoryData.ModelID = (enumModelID)(HistoryBuffRead[6] & 0x07);
    HistoryData.DeviceID = HistoryBuffRead[7] & 0xFF;
    HistoryData.ActionCause = (enumHistoryActionCause)(HistoryBuffRead[8] & 0x0F);
    HistoryData.ResultState = (enumHistoryResult)(HistoryBuffRead[9] & 0x0F);

    HistoryData.Pressure = (s[0] + (s[1] << 8) + (s[2] << 16) + (s[3] << 24)) / 100.0f;
    HistoryData.Temperature = (s1[0] + (s1[1] << 8) + (s1[2] << 16) + (s1[3] << 24)) / 100.0f;
}

void Flash_History_Write(uint8_t model, uint8_t action_cause, uint8_t result_state, float pressure, float temperature)
{
    uint32_t number;
    uint32_t TmpPressure = 0;
    uint32_t TmpTemperature = 0;

    TmpPressure = (uint32_t)(pressure * 100);
    TmpTemperature = (uint32_t)(temperature * 100);

    number = FlashRead_Uint32(0);
    if(number > 524288 - 2) {
        number = 1;
    }
    FlashLocate = number;

    HistoryBuffWrite[0] = (current_date.year) & 0x3F;
    HistoryBuffWrite[1] = current_date.month & 0x0F;
    HistoryBuffWrite[2] = current_date.day & 0x1F;
    HistoryBuffWrite[3] = current_time.hour & 0x1F;
    HistoryBuffWrite[4] = current_time.minute & 0x3F;
    HistoryBuffWrite[5] = current_time.second & 0x3F;

    HistoryBuffWrite[6] = model & 0x07;
    HistoryBuffWrite[7] = DeviceID & 0xFF;
    HistoryBuffWrite[8] = action_cause & 0x0F;
    HistoryBuffWrite[9] = result_state & 0x0F;

    HistoryBuffWrite[10] = (TmpPressure) & 0xFF;
    HistoryBuffWrite[11] = (TmpPressure >> 8) & 0xFF;
    HistoryBuffWrite[12] = (TmpPressure >> 16) & 0xFF;
    HistoryBuffWrite[13] = (TmpPressure >> 24) & 0xFF;

    HistoryBuffWrite[14] = (TmpTemperature) & 0xFF;
    HistoryBuffWrite[15] = (TmpTemperature >> 8) & 0xFF;
    HistoryBuffWrite[16] = (TmpTemperature >> 16) & 0xFF;
    HistoryBuffWrite[17] = (TmpTemperature >> 24) & 0xFF;

    W25QXX_Write(HistoryBuffWrite, number * HISTORY_RECORD_SIZE, HISTORY_RECORD_SIZE);
    number++;

    MyI2C_WriteUlong(ADDR_SPI_FLASH_ADDR, number);
}


void SetupState(enumErrorAlarm mErrorAlarm)
{
    if((InterimState == 9) && (mErrorAlarm == Opened))
    {
        mErrorAlarm = Closing;
    }

    switch(mErrorAlarm)
    {
        case NoError:
            snprintf(acStateStr, 10, "%s", "          ");
            ErrorAlarm = NoError;
            break;
        case CloseError:
            snprintf(acStateStr, 10, "%s", "关阀故障      ");
            ErrorAlarm = CloseError;
            break;
        case OpenError:
            snprintf(acStateStr, 10, "%s", "开阀故障      ");
            ErrorAlarm = OpenError;
            break;
        case SensorError:
            snprintf(acStateStr, 10, "%s", "传感器故障");
            ErrorAlarm = SensorError;
            break;
        case Opening:
            snprintf(acStateStr, 10, "%s", "开阀中       ");
            ErrorAlarm = Opening;
            break;
        case Closing:
            snprintf(acStateStr, 10, "%s", "关阀中       ");
            ErrorAlarm = Closing;
            break;
        case Opened:
            snprintf(acStateStr, 10, "%s", "已开阀       ");
            ErrorAlarm = Opened;
            break;
        case Closed:
            snprintf(acStateStr, 10, "%s", "已关阀       ");
            ErrorAlarm = Closed;
            break;
        case OverPressClose:
            snprintf(acStateStr, 10, "%s", "超压关阀      ");
            ErrorAlarm = OverPressClose;
            break;
        case UnderPressClose:
            snprintf(acStateStr, 10, "%s", "欠压关阀      ");
            ErrorAlarm = UnderPressClose;
            break;
        case OverTempClose:
            snprintf(acStateStr, 10, "%s", "超温关阀      ");
            ErrorAlarm = OverTempClose;
            break;
        case RemoteClose:
            snprintf(acStateStr, 10, "%s", "远程关阀      ");
            ErrorAlarm = RemoteClose;
            break;
        case MotorStallError:
            snprintf(acStateStr, 10, "%s", "电机堵转      ");
            ErrorAlarm = MotorStallError;
            break;
        default:
            break;
    }
}




	

