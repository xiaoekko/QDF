    SelectMenuID = 1;
    MaxSelectMenuID = 10;

    MotorStop();

    MaxPressure = 10.0f;
    MinPressure = 2.0f;

    uCoilsStatusLO.Bit4 = 0;
    uCoilsStatusLO.Bit5 = 0;
    uCoilsStatusLO.Byte = 0;
    uCoilsStatusHI.Byte = 0;
    uInputStatusLO.Byte = 0;
