/**
 * @brief 根据开关位传感器同步阀门显示状态
 */
void SyncValveDisplayStateFromSensors(void)
{
    if((OpenSensor == GPIO_PIN_RESET) && (CloseSensor == GPIO_PIN_SET)) {
        uCoilsStatusLO.Bit2 = 1;
        uCoilsStatusLO.Bit3 = 0;
        snprintf(acStateStr, 10, "%s", "已开阀       ");
        ErrorAlarm = Opened;
    }
    else if((OpenSensor == GPIO_PIN_SET) && (CloseSensor == GPIO_PIN_RESET)) {
        uCoilsStatusLO.Bit2 = 0;
        uCoilsStatusLO.Bit3 = 1;
        snprintf(acStateStr, 10, "%s", "已关阀       ");
        ErrorAlarm = Closed;
    }
    else {
        uCoilsStatusLO.Bit2 = 0;
        uCoilsStatusLO.Bit3 = 0;
        snprintf(acStateStr, 10, "%s", "          ");
        ErrorAlarm = NoError;
    }
}

/**
