void 		ForthInterfaceFunc(void) 						// 	第四页 - 历史记录
{
    static uint8_t first_draw = 1;
    
    // 静态变量存储上次显示的值
    static char last_time_str[20] = {0};
    static char last_battery_str[10] = {0};
    static uint8_t last_battery_level = 0xFF;
    
    // 历史记录刷新相关静态变量
    static uint32_t last_history_update = 0;
    static uint32_t last_max_number = 0;
    static uint32_t last_page_start = 0;
    static uint8_t force_history_refresh = 0;
    
    if(g_page_reset_flag) {
        first_draw = 1;
        g_page_reset_flag = 0;
        g_history_page_refresh_flag = 0;
        force_history_refresh = 1;
        
        // 切换到历史页时重置缓存，执行一次完整首绘
        memset(last_time_str, 0, sizeof(last_time_str));
        memset(last_battery_str, 0, sizeof(last_battery_str));
        last_battery_level = 0xFF;
        last_history_update = 0;
        last_max_number = 0;
        last_page_start = 0;
    } else if(g_history_page_refresh_flag) {
        // 页内翻页只刷新历史列表，不再整屏重绘
        g_history_page_refresh_flag = 0;
        force_history_refresh = 1;
    }
    
    
    // 当前值变量声明
    char current_time_str[20], current_battery_str[10];
    uint8_t current_battery_level;
    
    I2CFlag = 1;
    
    // 定时读取传感器数据
    static uint32_t last_time_update = 0;
    if (HAL_GetTick() - last_time_update > 1000) {
        PCF8563_GetTime(&current_time);
        PCF8563_GetDate(&current_date);
        last_time_update = HAL_GetTick();
    }
    
    // 读取电池电压
    static uint32_t last_battery_update = 0;
    if (HAL_GetTick() - last_battery_update > 500) {
        battery_voltage = Get_Battery_Voltage();
        last_battery_update = HAL_GetTick();
    }
    
    // 检查历史记录是否需要刷新（每2秒检查一次）
    uint8_t need_history_refresh = 0;
    uint32_t current_max_number = last_max_number;
    if (HAL_GetTick() - last_history_update > 2000 || force_history_refresh || number != last_page_start) {
        current_max_number = FlashRead_Uint32(0);
        if (current_max_number != last_max_number || number != last_page_start || force_history_refresh) {
            need_history_refresh = 1;
            last_max_number = current_max_number;
            last_page_start = number;
        }
        last_history_update = HAL_GetTick();
        force_history_refresh = 0;
    }
    
    // 生成当前显示字符串
    sprintf(current_time_str, "%02d:%02d:%02d", current_time.hour, current_time.minute, current_time.second);
    
    // 计算电池电量等级并处理未接电池的情况
    float display_voltage = battery_voltage;
    if (battery_voltage < 1.0f) {
        display_voltage = 24.0f;
    }
    sprintf(current_battery_str, "%.1fV", display_voltage);
    
    // 计算电池电量等级
    if(display_voltage <= 20) current_battery_level = 1;
    else if(display_voltage < 24) current_battery_level = 2;
    else if(display_voltage < 33) current_battery_level = 3;
    else current_battery_level = 4;
    
    // 首次绘制完整界面
    if(first_draw) {
        // ==================== 背景设置 ====================
        GUI_SetBkColor(GUI_WHITE);
        GUI_Clear();
        
        // 绘制渐变背景
        GUI_RECT bg_rect = {0, 0, 320, 240};
        GUI_DrawGradientV(bg_rect.x0, bg_rect.y0, bg_rect.x1, bg_rect.y1, GUI_LIGHTBLUE, GUI_WHITE);
        
        // ==================== 顶部标题栏 (0-35) ====================
        GUI_SetColor(GUI_DARKBLUE);
        GUI_FillRoundedRect(5, 5, 315, 35, 8);
        GUI_SetColor(GUI_LIGHTBLUE);
        GUI_DrawRoundedRect(5, 5, 315, 35, 8);
        
        // 添加标题栏阴影
        GUI_SetColor(GUI_GRAY_C0);
        GUI_DrawLine(6, 36, 316, 36);
        
        // 标题 - 历史记录
        GUI_SetFont(&GUI_FontHZ_SimSun_2424);
        GUI_SetBkColor(GUI_DARKBLUE);
        GUI_SetColor(GUI_WHITE);
        GUI_DispStringAt("历史记录", 12, 8);
        
        // 历史列表底板只绘制一次，翻页时复用，减少整屏闪烁
        GUI_SetColor(0xEAF4FF);
        GUI_FillRoundedRect(5, 40, 315, 235, 10);
        GUI_SetColor(0xB8CCE4);
        GUI_DrawRoundedRect(5, 40, 315, 235, 10);
        
        first_draw = 0;
        need_history_refresh = 1; // 首次绘制时强制刷新历史记录
    }
    
    // ==================== 历史记录卡片绘制/刷新 ====================
    if(need_history_refresh) {
        uint32_t maxnumber = last_max_number;
        
        // 刷新列表区域顶部信息，增强翻页时的层次感
        GUI_SetColor(0xEAF4FF);
        GUI_FillRect(12, 42, 308, 58);
        GUI_SetColor(0xB8CCE4);
        GUI_DrawLine(15, 60, 305, 60);
        GUI_SetBkColor(0xEAF4FF);
        GUI_SetColor(0x5B6B7A);
        GUI_SetFont(&GUI_Font16_ASCII);
        if(maxnumber > 1) {
            uint32_t total_records = maxnumber - 1;
            uint32_t page_end = number + 4;
            if(page_end > total_records) {
                page_end = total_records;
            }
            sprintf(dispbuff, "%03lu-%03lu/%03lu", (unsigned long)number, (unsigned long)page_end, (unsigned long)total_records);
            GUI_DispStringAt(dispbuff, 200, 43);
        } else {
            GUI_DispStringAt("000-000/000", 200, 43);
        }
        
        // 绘制5个历史记录卡片
        for(int i = 0; i < 5; i++) {
            uint32_t record_number = number + i;
            uint16_t card_y = 62 + i * 34;
            uint16_t card_height = 31;
            
            // 检查记录是否存在
            if(record_number >= maxnumber) {
                GUI_SetColor(0xF3F4F6);
                GUI_FillRoundedRect(10, card_y, 310, card_y + card_height, 8);
                GUI_SetColor(0xD1D5DB);
                GUI_DrawRoundedRect(10, card_y, 310, card_y + card_height, 8);
                
                GUI_SetBkColor(0xF3F4F6);
                GUI_SetColor(0x9CA3AF);
                GUI_SetFont(&GUI_FontHZ_SimSun_1616);
                GUI_DispStringAt("暂无记录", 128, card_y + 8);
                continue;
            }
            
            Flash_History_Read(maxnumber - record_number);
            
            GUI_COLOR card_bg_color = (i % 2 == 0) ? GUI_WHITE : 0xF8FAFC;
            GUI_COLOR card_border_color = (i % 2 == 0) ? 0x3B82F6 : 0x10B981;
            
            // 每次只覆盖卡片区域，避免整块区域先擦后画造成闪烁
            GUI_SetColor(card_bg_color);
            GUI_FillRoundedRect(10, card_y, 310, card_y + card_height, 8);
            GUI_SetColor(card_border_color);
            GUI_DrawRoundedRect(10, card_y, 310, card_y + card_height, 8);
            
            GUI_SetBkColor(card_bg_color);
            GUI_SetColor(0x374151);
            
            GUI_SetFont(&GUI_Font16_ASCII);
            sprintf(dispbuff, "%03lu", (unsigned long)record_number);
            GUI_DispStringAt(dispbuff, 16, card_y + 1);
            
            GUI_SetFont(&GUI_Font16_ASCII);
            sprintf(dispbuff, "20%02d-%02d-%02d %02d:%02d:%02d", 
                    HistoryData.Year, HistoryData.Month, HistoryData.Day,
                    HistoryData.Hour, HistoryData.Min, HistoryData.Second);
            GUI_DispStringAt(dispbuff, 46, card_y + 1);
            
            GUI_SetFont(&GUI_Font16_ASCII);
            GUI_SetColor(0x6B7280);
            sprintf(dispbuff, "%.1fMPa", HistoryData.Pressure);
            GUI_DispStringAt(dispbuff, 46, card_y + 15);
            
            sprintf(dispbuff, "%.1f", HistoryData.Temperature);
            GUI_DispStringAt(dispbuff, 118, card_y + 15);
            
            int x_temp_dist = GUI_GetStringDistX(dispbuff);
            GUI_SetFont(&GUI_FontHZ_SimSun_1616);
            GUI_DispStringAt("℃", 118 + x_temp_dist, card_y + 15);
            GUI_SetFont(&GUI_Font16_ASCII);
            
            GUI_SetFont(&GUI_FontHZ_SimSun_1616);
            {
                char cause_str[12] = {0};
                char result_str[12] = {0};
                GUI_COLOR cause_color = 0x2563EB;
                GUI_COLOR result_color = 0x059669;
                int cause_x = 196;
                int result_x = 262;
                int status_y = card_y + 15;
                uint8_t show_cause = 1;

                switch(HistoryData.ActionCause) {
                    case HistoryActionNone: show_cause = 0; break;
                    case HistoryActionRemoteClose: strcpy(cause_str, "远程关阀"); cause_color = 0x2563EB; break;
                    case HistoryActionOverPressClose: strcpy(cause_str, "超压关阀"); cause_color = 0xDC2626; break;
                    case HistoryActionUnderPressClose: strcpy(cause_str, "欠压关阀"); cause_color = 0xEA580C; break;
                    case HistoryActionOverTempClose: strcpy(cause_str, "超温关阀"); cause_color = 0xDC2626; break;
                    case HistoryActionManual:
                    default: strcpy(cause_str, "手动操作"); cause_color = 0x2563EB; break;
                }

                switch(HistoryData.ResultState) {
                    case HistoryResultOpened: strcpy(result_str, "已开阀"); result_color = 0x059669; break;
                    case HistoryResultClosed: strcpy(result_str, "已关阀"); result_color = 0x059669; break;
                    case HistoryResultOpenError: strcpy(result_str, "开阀故障"); result_color = 0xDC2626; break;
                    case HistoryResultCloseError: strcpy(result_str, "关阀故障"); result_color = 0xDC2626; break;
                    case HistoryResultSensorError: strcpy(result_str, "传感故障"); result_color = 0xEA580C; break;
                    case HistoryResultMotorStallError: strcpy(result_str, "电机堵转"); result_color = 0xDC2626; break;
                    default: strcpy(result_str, "未知"); result_color = 0x6B7280; break;
                }

                if(show_cause) {
                    GUI_SetColor(cause_color);
                    GUI_DispStringAt(cause_str, cause_x, status_y);
                }
                GUI_SetColor(result_color);
                GUI_DispStringAt(result_str, show_cause ? result_x : 220, status_y);
            }
        }
    }
    
    // ==================== 局部更新区域 ====================
    
    // 顶部标题栏 - 时间
    if(strcmp(last_time_str, current_time_str) != 0) {
        GUI_SetColor(GUI_DARKBLUE);
        GUI_FillRect(130, 8, 210, 32);
        GUI_SetFont(&GUI_Font20_ASCII);
        GUI_SetBkColor(GUI_DARKBLUE);
        GUI_SetColor(GUI_WHITE);
        GUI_DispStringAt(current_time_str, 132, 9);
        strcpy(last_time_str, current_time_str);
    }
    
    // 顶部标题栏 - 电池状态
    if(last_battery_level != current_battery_level || strcmp(last_battery_str, current_battery_str) != 0) {
        // 清除旧电池图标和电压
